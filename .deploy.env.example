# 复制为 .deploy.env 并填写实际值（.deploy.env 已在 .gitignore 中）
# 本地执行 make push 时会读取此文件

# SSH 登录用户（需与服务器 setup 脚本创建的 aisearch 用户一致）
DEPLOY_HOST=aisearch@your-server.com

# 服务器上 bare 仓库路径
DEPLOY_REPO=/var/git/aisearch.git

# 推送并部署的分支
DEPLOY_BRANCH=main

# git remote 名称
DEPLOY_REMOTE=deploy

# 部署方式: native（直接编译+systemd）或 docker（容器部署）
DEPLOY_MODE=docker
